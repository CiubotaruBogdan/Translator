graph TB
    subgraph USERS["🌐 Rețea Locală"]
        B1["Browser 1<br/><i>Desktop</i>"]
        B2["Browser 2<br/><i>Laptop</i>"]
        B3["Browser N<br/><i>Telefon / Tabletă</i>"]
    end

    subgraph HOST["🖥️ Windows 11 Host"]
        PM["Podman Engine<br/><i>Container Runtime</i>"]
        
        subgraph OLLAMA["Ollama (GPU)"]
            OA["Ollama API<br/><i>:11434</i>"]
            OM["LLM Models<br/><i>translategemma, llama3, etc.</i>"]
        end

        subgraph CONTAINER["📦 Container: traducator-offline"]
            EP["entrypoint.sh<br/><i>Auto-detect Ollama IP</i><br/><i>Network diagnostics</i>"]
            
            subgraph BACKEND["FastAPI Backend (server.py)"]
                API["REST API<br/><i>/api/translate</i><br/><i>/api/status</i><br/><i>/api/jobs</i><br/><i>/api/network-diag</i>"]
                WS["WebSocket<br/><i>/ws/dashboard</i>"]
                SSE["SSE Events<br/><i>/api/jobs/{id}/events</i>"]
                PIPE["Translation Pipeline<br/><i>Extract → Chunk → Translate → Assemble</i>"]
                CRON["Cleanup Scheduler<br/><i>Daily @ midnight</i>"]
            end

            subgraph DOCPROC["Document Processing"]
                DOCX["python-docx<br/><i>Format Preservation</i>"]
                PDF2D["pdf2docx<br/><i>Digital PDF → DOCX</i>"]
                OCR["Tesseract OCR<br/><i>Scanned PDF → Text</i>"]
                PDFP["pdfplumber<br/><i>Fallback PDF reader</i>"]
                LO["LibreOffice Headless<br/><i>DOCX → PDF export</i>"]
            end

            subgraph LT["LibreTranslate (CPU)"]
                LTA["LibreTranslate API<br/><i>:5000 (internal)</i>"]
                ARGOS["Argos Translate Models<br/><i>ro ↔ en ↔ fr</i>"]
            end

            subgraph FRONTEND["Web Frontend"]
                IDX["index.html<br/><i>SPA Dashboard</i>"]
                LOG["logs.html<br/><i>Logs & Network Diag</i>"]
            end

            subgraph STORAGE["Storage"]
                UP["/app/uploads"]
                OUT["/app/outputs"]
            end
        end
    end

    B1 & B2 & B3 -->|"HTTP :80"| API
    B1 & B2 & B3 -->|"WebSocket"| WS
    API -->|"SSE stream"| B1 & B2 & B3
    API --> FRONTEND
    API --> PIPE
    PIPE --> DOCPROC
    PIPE -->|"Parallel chunks"| LTA
    PIPE -->|"Parallel chunks"| OA
    OA --> OM
    LTA --> ARGOS
    DOCPROC --> STORAGE
    PIPE --> STORAGE
    EP -->|"starts"| LTA
    EP -->|"starts"| API

    classDef container fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#0c4a6e
    classDef host fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#78350f
    classDef ollama fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#14532d
    classDef users fill:#ede9fe,stroke:#7c3aed,stroke-width:2px,color:#3b0764
    classDef backend fill:#dbeafe,stroke:#2563eb,stroke-width:1px,color:#1e3a5f
    classDef docproc fill:#fce7f3,stroke:#db2777,stroke-width:1px,color:#831843
    classDef lt fill:#d1fae5,stroke:#059669,stroke-width:1px,color:#064e3b
    classDef storage fill:#f1f5f9,stroke:#64748b,stroke-width:1px,color:#334155

    class CONTAINER container
    class HOST host
    class OLLAMA ollama
    class USERS users
